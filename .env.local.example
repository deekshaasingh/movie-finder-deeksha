# Copy this file to .env.local and fill in your own TMDB API key.
# Get a free key at https://www.themoviedb.org/settings/api
# NEXT_PUBLIC_ prefix exposes it to the browser, which is required here
# because we fetch from the client. This is a read-only public API key.

NEXT_PUBLIC_TMDB_API_KEY=your_tmdb_api_key_here